---
layout: "base.liquid"
---

<div class="columns">
  <div class="col">
    {% if book.cover %}<div class="book-cover" style="width: fit-content;"><img src="/images/books/{{book.cover}}" alt="{{book.title}}" title="{{book.title}}" style="height: calc({{book.height}} * 19rem / 10); width: auto;" /></div>{% endif %}

    {{ content }}
  </div>

  <div class="col">
    {% if highlights.length > 0 %}
    <section>
      <h3>Цитаты</h3>
      <div>
      {% for highlight in highlights %}<blockquote><p>{{ highlight | newline_to_br }}</p></blockquote>{% endfor %}
      </div>
    </section>
    {% endif %}
  </div>
</div>