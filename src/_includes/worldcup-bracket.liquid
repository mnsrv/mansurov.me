{% comment %}
  Knockout bracket: one row of round columns, each with top and bottom draw halves
  side by side. They only meet in the final. Param: knockout.
{% endcomment %}

{% assign r32a = knockout.round32 | slice: 0, 8 %}
{% assign r32b = knockout.round32 | slice: 8, 8 %}
{% assign r16a = knockout.round16 | slice: 0, 4 %}
{% assign r16b = knockout.round16 | slice: 4, 4 %}
{% assign qfa = knockout.quarterfinals | slice: 0, 2 %}
{% assign qfb = knockout.quarterfinals | slice: 2, 2 %}
{% assign sfa = knockout.semifinals | slice: 0, 1 %}
{% assign sfb = knockout.semifinals | slice: 1, 1 %}
{% assign currentRound = knockout.currentRound %}
{% assign finalCurrent = false %}
{% if currentRound == "finalstage" %}{% assign finalCurrent = true %}{% endif %}
{% assign finalCompact = true %}
{% if finalCurrent %}{% assign finalCompact = false %}{% endif %}

<div class="wc-knockout">
  <div class="wc-bracket">
    {% include "worldcup-round.liquid", title: "Round of 32", matchesTop: r32a, matchesBottom: r32b, pair: true, roundId: "round32", currentRound: currentRound %}
    {% include "worldcup-round.liquid", title: "Round of 16", matchesTop: r16a, matchesBottom: r16b, roundId: "round16", currentRound: currentRound %}
    {% include "worldcup-round.liquid", title: "Quarter-finals", matchesTop: qfa, matchesBottom: qfb, roundId: "quarterfinals", currentRound: currentRound %}
    {% include "worldcup-round.liquid", title: "Semi-finals", matchesTop: sfa, matchesBottom: sfb, roundId: "semifinals", currentRound: currentRound %}
  </div>

  <section class="wc-final-block{% if finalCurrent %} wc-round-current{% else %} wc-round-compact{% endif %}">
    <h4 class="wc-round-title">Final</h4>
    {% include "worldcup-match.liquid", m: knockout.final, compact: finalCompact %}
    <h4 class="wc-third-title">Third place</h4>
    {% include "worldcup-match.liquid", m: knockout.thirdPlace, compact: finalCompact %}
  </section>
</div>
