{% comment %}
  Knockout bracket in a single horizontal flow: Round of 32 → Round of 16 →
  Quarter-finals → Semi-final → Final/Third place.
{% endcomment %}

<div class="wc-knockout wc-bracket">
  <section class="wc-half">
    {% include "worldcup-round.liquid", title: "Round of 32", matches: knockout.round32, pair: true %}
    {% include "worldcup-round.liquid", title: "Round of 16", matches: knockout.round16 %}
    {% include "worldcup-round.liquid", title: "Quarter-finals", matches: knockout.quarterfinals %}
    {% include "worldcup-round.liquid", title: "Semi-final", matches: knockout.semifinals %}
    <div class="wc-final-block wc-round">
      <h4 class="wc-section-heading">Final</h4>
      <div class="wc-round-matches wc-final-matches">
        <div class="wc-final-slot">
          <h5 class="wc-final-subheader">Final</h5>
          {% include "worldcup-match.liquid", m: knockout.final %}
        </div>
        <div class="wc-final-slot wc-third-slot">
          <h5 class="wc-final-subheader">Third place</h5>
          {% include "worldcup-match.liquid", m: knockout.thirdPlace %}
        </div>
      </div>
    </div>
  </section>
</div>
