{% comment %}
  Renders one World Cup group: standings table (computed) + fixtures.
  Param: group — { name, standings[], matches[] }
  Top 2 rows are highlighted as qualified.
{% endcomment %}

<div class="wc-group">
  <h3>Group {{ group.name }}</h3>
  <table class="wc-table">
    <thead>
      <tr>
        <th class="wc-pos">#</th>
        <th class="wc-team">Team</th>
        <th title="Played">P</th>
        <th title="Won">W</th>
        <th title="Drawn">D</th>
        <th title="Lost">L</th>
        <th title="Goals for">GF</th>
        <th title="Goals against">GA</th>
        <th title="Goal difference">GD</th>
        <th title="Points">Pts</th>
      </tr>
    </thead>
    <tbody>
      {% for row in group.standings %}
        <tr class="{% if row.result == 'in' %}wc-adv{% elsif row.result == 'out' %}wc-gone{% endif %}">
          <td class="wc-pos">{{ row.rank }}</td>
          <td class="wc-team"><span class="wc-tname" title="{{ row.name }}">{% if row.flag != "" %}{{ row.flag }} {% endif %}{{ row.name }}</span></td>
          <td>{{ row.played }}</td>
          <td>{{ row.won }}</td>
          <td>{{ row.drawn }}</td>
          <td>{{ row.lost }}</td>
          <td>{{ row.gf }}</td>
          <td>{{ row.ga }}</td>
          <td>{% if row.gd > 0 %}+{% endif %}{{ row.gd }}</td>
          <td class="wc-pts">{{ row.points }}</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  <ul class="wc-fixtures">
    {% for m in group.matches %}
      <li{% if m.homeScore == null or m.awayScore == null %} data-wc-home="{{ m.home }}" data-wc-away="{{ m.away }}"{% endif %}>
        <span class="wc-date wc-when">{{ m.warsawDate }} <span class="wc-time">{{ m.warsawTime }}</span></span>
        <span class="wc-home">{{ m.home }}</span>
        <span class="wc-score">{% if m.homeScore != null and m.awayScore != null %}{{ m.homeScore }}&ndash;{{ m.awayScore }}{% else %}v{% endif %}</span>
        <span class="wc-away">{{ m.away }}</span>
      </li>
    {% endfor %}
  </ul>

  <details class="wc-teaminfo">
    <summary>Team profiles</summary>
    <dl>
      {% for t in group.teams %}
        <dt>{% if t.flag != "" %}{{ t.flag }} {% endif %}{{ t.name }}</dt>
        <dd>
          <span title="Head coach">👔 {{ t.coach }}</span>
          <span title="Best World Cup result">🏆 {{ t.best }}</span>
          <span title="Star player">⭐ {{ t.star }}</span>
        </dd>
      {% endfor %}
    </dl>
  </details>
</div>
