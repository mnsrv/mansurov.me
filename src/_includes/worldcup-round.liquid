{% comment %}
  One bracket round column. With pair=true the matches are grouped into pairs (the
  two that meet next) — used for the Round of 32. Params: title, matches, pair,
  roundId, currentRound.
{% endcomment %}
{% assign isCurrent = false %}
{% if roundId == currentRound %}{% assign isCurrent = true %}{% endif %}
{% assign compact = true %}
{% if isCurrent %}{% assign compact = false %}{% endif %}
<div class="wc-round{% if isCurrent %} wc-round-current{% else %} wc-round-compact{% endif %}">
  <h4>{{ title }}</h4>
  <div class="wc-round-matches">
    {% if pair %}
      {% for m in matches %}
        {% assign rem = forloop.index0 | modulo: 2 %}
        {% if rem == 0 %}<div class="wc-pair">{% endif %}
          {% include "worldcup-match.liquid", m: m, compact: compact %}
        {% if rem == 1 or forloop.last %}</div>{% endif %}
      {% endfor %}
    {% else %}
      {% for m in matches %}{% include "worldcup-match.liquid", m: m, compact: compact %}{% endfor %}
    {% endif %}
  </div>
</div>
