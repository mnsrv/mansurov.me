{% comment %}
  Schedule grouped by phase (round) → day. Param: schedule —
  [{ name, past, days:[{ label, matches:[{warsawTime, home, homeFlag, away, awayFlag, homeScore, awayScore}] }] }]
{% endcomment %}

{% assign shownSep = false %}
{% for phase in schedule %}
  {% if phase.past and shownSep == false %}
    <hr class="wc-sched-sep" />
    {% assign shownSep = true %}
  {% endif %}
  <h3 class="wc-sched-phase {% if phase.past %}wc-sched-past{% endif %}">{{ phase.name }}</h3>
  {% for day in phase.days %}
    <h4 class="wc-sched-day {% if phase.past %}wc-sched-past{% endif %}">{{ day.label }}</h4>
    <ul class="wc-fixtures wc-sched">
      {% for m in day.matches %}
        <li{% if m.homeScore == null or m.awayScore == null %} data-wc-home="{{ m.home }}" data-wc-away="{{ m.away }}"{% endif %}>
          <span class="wc-date wc-when"><span class="wc-time">{{ m.warsawTime }}</span></span>
          <span class="wc-home">{{ m.home }}</span>
          <span class="wc-flag">{{ m.homeFlag }}</span>
          <span class="wc-score">{% if m.homeScore != null and m.awayScore != null %}{{ m.homeScore }}&ndash;{{ m.awayScore }}{% if m.hasPenalties %} <span class="wc-sched-pens">({{ m.homePenalties }}&ndash;{{ m.awayPenalties }})</span>{% endif %}{% else %}v{% endif %}</span>
          <span class="wc-flag">{{ m.awayFlag }}</span>
          <span class="wc-away">{{ m.away }}</span>
        </li>
      {% endfor %}
    </ul>
  {% endfor %}
{% endfor %}
