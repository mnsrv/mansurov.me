{% comment %}
  Ranking of the 12 third-placed teams; top 8 advance. Param: thirds.
{% endcomment %}
<table class="wc-table wc-thirds">
  <thead>
    <tr>
      <th class="wc-pos">#</th>
      <th class="wc-grp">Grp</th>
      <th class="wc-team">Team</th>
      <th title="Played">P</th>
      <th title="Won">W</th>
      <th title="Drawn">D</th>
      <th title="Lost">L</th>
      <th title="Goals for / against">+/&minus;</th>
      <th title="Goal difference">GD</th>
      <th title="Points">Pts</th>
    </tr>
  </thead>
  <tbody>
    {% for t in thirds %}
      <tr class="{% if t.advancing %}wc-qualify{% else %}wc-elim{% endif %}{% if t.seed == 8 %} wc-cutline{% endif %}">
        <td class="wc-pos">{{ t.seed }}</td>
        <td class="wc-grp">{{ t.group }}</td>
        <td class="wc-team"><span class="wc-tname" title="{{ t.name }}">{% if t.flag != "" %}{{ t.flag }} {% endif %}{{ t.name }}</span></td>
        <td>{{ t.played }}</td>
        <td>{{ t.won }}</td>
        <td>{{ t.drawn }}</td>
        <td>{{ t.lost }}</td>
        <td>{{ t.gf }}:{{ t.ga }}</td>
        <td>{% if t.gd > 0 %}+{% endif %}{{ t.gd }}</td>
        <td class="wc-pts">{{ t.points }}</td>
      </tr>
    {% endfor %}
  </tbody>
</table>
